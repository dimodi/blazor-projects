<TelerikTabStrip @bind-ActiveTabId="@ActiveTabId">
    <TabStripTab Title="Tab 1" Id="tab1">
        Content 1
    </TabStripTab>
    <TabStripTab Title="Tab 2" Id="tab2">
        Content 2
    </TabStripTab>
    <TabStripTab Title="Tab 3" Id="tab3">
        Content 3
    </TabStripTab>
</TelerikTabStrip>

@code {
    private string ActiveTabId { get; set; } = "tab1";
}
